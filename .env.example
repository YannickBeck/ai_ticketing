# ── Datenbank (Supabase) ────────────────────────────────────────────────────
# Transaction Pooler (PgBouncer) – für die laufende App (Port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct Connection – nur für Prisma-Migrations (Port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

AUTH_SECRET="generate-with-openssl-rand-base64-32"
QR_TOKEN_SECRET="generate-with-openssl-rand-base64-32"
QR_TOKEN_PEPPER="generate-with-openssl-rand-base64-32"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys (Test-Modus)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CONNECT_CLIENT_ID="ca_..."
STRIPE_CONNECTED_ACCOUNT_ID=""
STRIPE_PAYMENT_SUCCESS_URL="${NEXT_PUBLIC_APP_URL}/orders/{ORDER_ID}"
STRIPE_PAYMENT_CANCEL_URL="${NEXT_PUBLIC_APP_URL}/checkout/{ORDER_ID}"

# ── Notifications ────────────────────────────────────────────────────────────
EMAIL_PROVIDER="mock"
EMAIL_FROM="Spargelstand <noreply@example.com>"

WHATSAPP_PROVIDER="mock"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_WEBHOOK_SECRET=""
WHATSAPP_TEMPLATE_ORDER_CONFIRMED="spargel_order_confirmed_v1"
WHATSAPP_TEMPLATE_PICKUP_REMINDER="spargel_pickup_reminder_v1"
WHATSAPP_TEMPLATE_ORDER_CHANGED="spargel_order_changed_v1"
