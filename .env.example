# ============================================================
# AI Ticketing Buddy — Environment Variables
# Kopieren als .env und mit echten Werten befüllen
# NIEMALS .env committen! (.gitignore prüfen)
# Alle Secrets kommen in der Produktion aus Azure Key Vault
# ============================================================

# ── Azure OpenAI ──────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://oai-ai-ticketing-prod.openai.azure.com
AZURE_OPENAI_API_KEY=REPLACE_FROM_KEY_VAULT

# ── Azure AI Speech ───────────────────────────────────────────
SPEECH_REGION=westeurope
SPEECH_API_KEY=REPLACE_FROM_KEY_VAULT

# ── Azure Blob Storage ────────────────────────────────────────
BLOB_STORAGE_URL=https://staiticketing prod.blob.core.windows.net
BLOB_SAS_TOKEN=REPLACE_WITH_SAS_TOKEN  # oder Managed Identity verwenden
BLOB_STORAGE_CONNECTION=REPLACE_FROM_KEY_VAULT

# ── PostgreSQL (AI Buddy DB) ──────────────────────────────────
PG_HOST=pg-ai-ticketing-prod.postgres.database.azure.com
PG_AI_BUDDY_URL=postgresql://pgadmin:PASSWORD@pg-ai-ticketing-prod.postgres.database.azure.com/ai_buddy?sslmode=require
PG_N8N_URL=postgresql://pgadmin:PASSWORD@pg-ai-ticketing-prod.postgres.database.azure.com/n8n?sslmode=require

# ── Zammad ────────────────────────────────────────────────────
ZAMMAD_BASE_URL=https://ca-zammad-prod.azurecontainerapps.io
ZAMMAD_API_TOKEN=REPLACE_AFTER_SETUP

# ── n8n ───────────────────────────────────────────────────────
N8N_BASE_URL=https://ca-n8n-prod.azurecontainerapps.io
N8N_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_RANDOM
N8N_API_KEY=REPLACE_AFTER_SETUP

# ── Microsoft Graph (M365) ────────────────────────────────────
GRAPH_TENANT_ID=REPLACE_WITH_AZURE_TENANT_ID
GRAPH_CLIENT_ID=REPLACE_FROM_APP_REGISTRATION
GRAPH_CLIENT_SECRET=REPLACE_FROM_KEY_VAULT
SUPPORT_MAILBOX=support@deinedomaene.de

# ── Notifications ─────────────────────────────────────────────
TEAMLEAD_EMAIL=teamlead@deinedomaene.de
TEAMS_WEBHOOK_URL=REPLACE_WITH_TEAMS_INCOMING_WEBHOOK  # optional

# ── Security ──────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=REPLACE_WITH_32_BYTE_RANDOM

# ── Azure Subscription (nur für lokale az CLI Befehle) ────────
AZURE_SUBSCRIPTION_ID=REPLACE_WITH_SUBSCRIPTION_ID
AZURE_TENANT_ID=REPLACE_WITH_TENANT_ID
